<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.lis.professionalpracticesystem.graphicaluserinterface.controllers.ReportEvaluationWizardViewController">
   <children>
      <VBox spacing="18.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="25.0" left="35.0" right="35.0" top="25.0" />
         </padding>
         <children>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Dictamen de Evaluación del Reporte" textFill="#1a4f7c">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label text="Revise los metadatos y el archivo cargado para emitir observaciones y validar horas." textFill="#555555" />
               </children>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-radius: 5; -fx-background-radius: 5;">
               <padding>
                  <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
               </padding>
               <children>
                  <Label text="Datos Generales de la Entrega" textFill="#1a4f7c">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <HBox spacing="40.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Matrícula del Alumno:" textFill="#777777" />
                              <Label fx:id="enrollmentLabel" text="SXXXXXXXX">
                                 <font>
                                    <Font name="System Bold" size="13.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Tipo de Reporte:" textFill="#777777" />
                              <Label fx:id="reportTypeLabel" text="Reporte Mensual">
                                 <font>
                                    <Font name="System Bold" size="13.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Estado del Envío:" textFill="#777777" />
                              <Label fx:id="deliveryStatusLabel" text="A tiempo">
                                 <font>
                                    <Font name="System Bold" size="13.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Label text="Documento PDF Adjunto:" textFill="#777777" />
                        <Button fx:id="downloadPdfButton" onAction="#handleDownloadPdf" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-background-radius: 3; -fx-cursor: hand; -fx-font-weight: bold;" text="Descargar / Visualizar PDF 📄" />
                     </children>
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  
                  <VBox prefWidth="360.0" spacing="10.0" style="-fx-background-color: #fafafa; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6;">
                     <padding>
                        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                     </padding>
                     <children>
                        <Label text="Progreso de Actividades del Proyecto" textFill="#1a4f7c">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <Label text="Marque los entregables cubiertos en este reporte:" textFill="#666666">
                           <font>
                              <Font size="11.0" />
                           </font>
                        </Label>
                        <TableView fx:id="checklistTableView" prefHeight="200.0" style="-fx-background-radius: 4; -fx-border-color: #cbd5e1;" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="checkboxTableColumn" prefWidth="55.0" resizable="false" style="-fx-alignment: CENTER;" text="¿Ok?" />
                            <TableColumn fx:id="activityNameTableColumn" prefWidth="275.0" text="Descripción de la Actividad" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
                  
                  <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Dictamen del Docente:*">
                                       <font>
                                          <Font name="System Bold" size="13.0" />
                                       </font>
                                    </Label>
                                    <ComboBox fx:id="evaluationComboBox" onAction="#handleEvaluationSelection" prefHeight="30.0" prefWidth="210.0" promptText="Seleccione dictamen..." style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4;" />
                                 </children>
                              </VBox>
                              <VBox fx:id="hoursVBox" spacing="5.0">
                                 <children>
                                    <Label text="Horas a Acreditar (0 - 480):*">
                                       <font>
                                          <Font name="System Bold" size="13.0" />
                                       </font>
                                    </Label>
                                    <TextField fx:id="hoursTextField" prefHeight="30.0" prefWidth="150.0" promptText="Ej. 40" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4;" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                           <children>
                              <Label text="Retroalimentación y Observaciones:*">
                                 <font>
                                    <Font name="System Bold" size="13.0" />
                                 </font>
                              </Label>
                              <TextArea fx:id="observationsTextArea" prefHeight="120.0" promptText="Escriba aquí los comentarios o las correcciones que el alumno debe atender..." style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4;" wrapText="true" VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
               </children>
            </HBox>

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button fx:id="cancelButton" onAction="#handleCancel" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Cancelar">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
                  <Button fx:id="submitButton" onAction="#handleSubmitEvaluation" prefHeight="35.0" prefWidth="160.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Registrar Dictamen">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
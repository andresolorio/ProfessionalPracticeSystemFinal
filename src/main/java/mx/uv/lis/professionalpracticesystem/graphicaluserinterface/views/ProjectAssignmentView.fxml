<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="520.0" prefWidth="600.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.lis.professionalpracticesystem.graphicaluserinterface.controllers.ProjectAssignmentViewController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="45.0" layoutY="30.0" prefHeight="460.0" prefWidth="510.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4) ;" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="45.0" AnchorPane.rightAnchor="45.0" AnchorPane.topAnchor="30.0">
         <children>
            
            <Label text="Asignación de Proyecto a Estudiante" textFill="#0c4c84">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </Label>
            
            <GridPane hgap="15.0" vgap="15.0">
              <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="140.0" minWidth="10.0" prefWidth="130.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="340.0" minWidth="10.0" prefWidth="320.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="140.0" vgrow="SOMETIMES" /> </rowConstraints>
               <children>
                  <Label text="Estudiante:" textFill="#555555">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <ComboBox fx:id="studentComboBox" prefHeight="32.0" prefWidth="320.0" promptText="Seleccione Alumno" style="-fx-background-radius: 5; -fx-border-color: #dddddd; -fx-border-radius: 5;" GridPane.columnIndex="1" />
                  
                  <Label text="Proyecto:" textFill="#555555" GridPane.rowIndex="1">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <ComboBox fx:id="projectComboBox" prefHeight="32.0" prefWidth="320.0" promptText="Seleccione Proyecto" style="-fx-background-radius: 5; -fx-border-color: #dddddd; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  
                  <VBox alignment="TOP_RIGHT" spacing="2.0" GridPane.rowIndex="2">
                     <children>
                        <Label text="Exposición de Motivos:" textFill="#555555">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <Label text="(Obligatorio)" textFill="#888888">
                           <font>
                              <Font size="11.0" />
                           </font>
                        </Label>
                     </children>
                     <GridPane.margin>
                        <Insets top="5.0" />
                     </GridPane.margin>
                  </VBox>
                  <TextArea fx:id="reasonTextArea" prefHeight="130.0" prefWidth="320.0" promptText="Describa los motivos de la asignación (ej. Promedio académico, cupo agotado en opciones previas, asignación forzada...)" wrapText="true" style="-fx-background-radius: 5; -fx-border-color: #dddddd; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
               <VBox.margin>
                  <Insets left="10.0" right="20.0" />
               </VBox.margin>
            </GridPane>
            
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="assignButton" defaultButton="true" mnemonicParsing="false" onAction="#handleAssign" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #0c4c84; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Confirmar Asignación">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Button>
                  
                  <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #c82333; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
            
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="25.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
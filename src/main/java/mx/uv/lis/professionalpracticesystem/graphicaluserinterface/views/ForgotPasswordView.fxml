<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.lis.professionalpracticesystem.graphicaluserinterface.controllers.ForgotPasswordViewController">
   <children>
      <VBox alignment="CENTER" layoutX="100.0" layoutY="35.0" prefHeight="380.0" prefWidth="450.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
         <children>
            
            <Label fx:id="loginLabel1" text="Recuperación de Contraseña" textFill="#0c4c84">
               <font>
                  <Font name="System Bold" size="26.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            
            <VBox prefWidth="100.0" spacing="8.0">
               <children>
                  <Label fx:id="loginLabel" text="Ingresa tu correo para recibir un token de recuperación:" textFill="#555555">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <TextField fx:id="emailTextField" prefHeight="35.0" promptText="ejemplo@estudiantes.uv.mx" style="-fx-background-radius: 5; -fx-border-color: #dddddd; -fx-border-radius: 5; -fx-background-color: #fafafa;" />
               </children>
               <VBox.margin>
                  <Insets left="35.0" right="35.0" />
               </VBox.margin>
            </VBox>
            
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  
                  <Button defaultButton="true" mnemonicParsing="false" onAction="#handleSendCode" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #0c4c84; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Enviar Código">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #c82333; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin>
            </HBox>
            
         </children>
         <padding>
            <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>

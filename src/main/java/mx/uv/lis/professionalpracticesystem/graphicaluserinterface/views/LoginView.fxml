<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="450.0" prefWidth="650.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.lis.professionalpracticesystem.graphicaluserinterface.controllers.LoginViewController">
   <children>
      <VBox alignment="CENTER" layoutX="145.0" layoutY="35.0" prefHeight="380.0" prefWidth="360.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
         <children>
            
            <Label fx:id="loginLabel" text="Iniciar Sesión" textFill="#0c4c84">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            
            <VBox prefWidth="100.0" spacing="5.0">
               <children>
                  <Label fx:id="emailLabel" text="Correo Electrónico" textFill="#555555">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <TextField fx:id="emailTextField" prefHeight="35.0" promptText="ejemplo@estudiantes.uv.mx" style="-fx-background-radius: 5; -fx-border-color: #dddddd; -fx-border-radius: 5; -fx-background-color: #fafafa;" />
               </children>
               <VBox.margin>
                  <Insets left="30.0" right="30.0" />
               </VBox.margin>
            </VBox>
            
            <VBox prefWidth="100.0" spacing="5.0">
               <children>
                  <Label fx:id="passwordLabel" text="Contraseña" textFill="#555555">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <PasswordField fx:id="passwordTextField" prefHeight="35.0" promptText="••••••••••••" style="-fx-background-radius: 5; -fx-border-color: #dddddd; -fx-border-radius: 5; -fx-background-color: #fafafa;" />
               </children>
               <VBox.margin>
                  <Insets left="30.0" right="30.0" />
               </VBox.margin>
            </VBox>
            
            <Hyperlink fx:id="forgotPasswordLink" onAction="#handleForgotPassword" text="¿Olvidaste tu contraseña?" textFill="#0c4c84">
               <font>
                  <Font size="12.0" />
               </font>
               <VBox.margin>
                  <Insets top="-5.0" />
               </VBox.margin>
            </Hyperlink>
            
            <Button fx:id="loginButton" defaultButton="true" mnemonicParsing="false" onAction="#handleLogin" prefHeight="38.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Ingresar">
               <font>
                  <Font size="14.0" />
               </font>
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin>
            </Button>
            
         </children>
         <padding>
            <Insets bottom="30.0" top="25.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
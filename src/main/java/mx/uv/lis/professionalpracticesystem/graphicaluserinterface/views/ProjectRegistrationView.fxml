                        <ComboBox fx:id="technicalResponsibleComboBox" prefHeight="30.0" prefWidth="335.0" promptText="Seleccione un responsable" style="-fx-background-radius: 5; -fx-border-color: #dddddd; -fx-border-radius: 5;" GridPane.columnIndex="2" GridPane.rowIndex="11" />
                        
                        <Label fx:id="vacanciesLabel" text="Lugares disponibles:" textFill="#555555" GridPane.rowIndex="12"><font><Font name="System Bold" size="13.0" /></font></Label>
                        <Label text="*" textFill="RED" GridPane.columnIndex="1" GridPane.rowIndex="12"><font><Font name="System Bold" size="14.0" /></font><tooltip><Tooltip text="Este campo es obligatorio" /></tooltip></Label>
                        <TextField fx:id="vacanciesTextField" prefHeight="30.0" promptText="Ej. 3" style="-fx-background-radius: 5; -fx-border-color: #dddddd; -fx-border-radius: 5;" GridPane.columnIndex="2" GridPane.rowIndex="12" />

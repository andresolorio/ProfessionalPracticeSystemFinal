                        <Button fx:id="cancelButton" cancelButton="true" mnemonicParsing="false" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #c82333; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar">
                           <font><Font size="13.0" /></font>

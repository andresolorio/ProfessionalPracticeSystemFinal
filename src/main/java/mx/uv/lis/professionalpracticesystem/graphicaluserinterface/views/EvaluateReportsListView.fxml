<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.lis.professionalpracticesystem.graphicaluserinterface.controllers.EvaluateReportsListViewController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Evaluación de Reportes Disponibles" textFill="#1a4f7c">
                     <font>
                        <Font name="System Bold" size="26.0" />
                     </font>
                  </Label>
                  <Label text="Seleccione el reporte de un alumno asignado para revisar su contenido y emitir un dictamen." textFill="#555555">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
               </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Label text="Filtrar por Estado:">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <ComboBox fx:id="statusFilterComboBox" prefWidth="180.0" promptText="Todos" />
               </children>
            </HBox>

            <TableView fx:id="reportsTableView" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="enrollmentTableColumn" prefWidth="120.0" text="Matrícula" />
                  <TableColumn fx:id="typeTableColumn" prefWidth="150.0" text="Tipo de Reporte" />
                  <TableColumn fx:id="deliveryDateTableColumn" prefWidth="130.0" text="Fecha de Entrega" />
                  <TableColumn fx:id="deliveryStatusTableColumn" prefWidth="130.0" text="Envío" />
                  <TableColumn fx:id="reviewStatusTableColumn" prefWidth="150.0" text="Estado Revisión" />
                  <TableColumn fx:id="hoursTableColumn" prefWidth="120.0" text="Horas Cubiertas" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button fx:id="backButton" onAction="#handleBack" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 5;" text="Regresar">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
                  <Button fx:id="evaluateButton" onAction="#handleEvaluate" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 5;" text="Evaluar Reporte">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
                     </children>
                  </VBox>
                  
                  <VBox spacing="10.0" style="-fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-color: #fafafa; -fx-background-radius: 8;" GridPane.columnIndex="1">

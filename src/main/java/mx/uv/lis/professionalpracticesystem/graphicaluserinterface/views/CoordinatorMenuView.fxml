                     <children>
                        <Label style="-fx-font-weight: bold;" text="Experiencia Educativa" textFill="#0c4c84">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Button onAction="#handleRegisterEducativeExperience" prefHeight="32.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Registrar Experiencia Educativa" />
                        <Button onAction="#handleConsultEE" prefHeight="32.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Consultar Experiencia Educativa" />
                        <Button onAction="#handleAssignStudentToEE" prefHeight="32.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Asignar Alumno a Experiencia Educativa" />
                     </children>
                  </VBox>
                  
               </children>
               <VBox.margin>
                  <Insets left="15.0" right="15.0" />
               </VBox.margin>
            </GridPane>
            
            <HBox alignment="BOTTOM_RIGHT" prefHeight="50.0" prefWidth="690.0" spacing="15.0">
               <children>
                  <Button fx:id="switchPerformanceRoleButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="180.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Ver funciones de Profesor" />
                  <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#handleLogout" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #c82333; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Cerrar Sesión" />
               </children>
               <VBox.margin>
                  <Insets right="15.0" top="10.0" />
               </VBox.margin>
            </HBox>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Button onAction="#handleRegisterStudent" prefHeight="32.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Registrar Alumno" />

                        <Label style="-fx-font-weight: bold;" text="Gestión de Proyectos" textFill="#0c4c84">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Button onAction="#handleRegisterProject" prefHeight="32.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Registrar Proyecto" />
                        <Button onAction="#handleViewProjectsList" prefHeight="32.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Lista de Proyectos" />
                        <Button onAction="#handleAssignProject" prefHeight="32.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Asignar Proyecto" />
                        <Button onAction="#handleManageProjectActivities" prefHeight="32.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Gestionar Actividades de Proyectos" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="10.0" style="-fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-color: #fafafa; -fx-background-radius: 8;" GridPane.rowIndex="1">
                     <padding>
                        <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
                     </padding>
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Organizaciones y Responsables" textFill="#0c4c84">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Button onAction="#handleRegisterOrganization" prefHeight="28.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Registrar Organización" />
                        <Button onAction="#handleViewOrganizations" prefHeight="28.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Consultar Organizaciones" />
                        <Button onAction="#handleRegisterResponsible" prefHeight="28.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Registrar Responsable" />
                        <Button onAction="#handleViewResponsibles" prefHeight="28.0" prefWidth="300.0" style="-fx-background-color: #0c4c84; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Consultables Responsables" />
                     </children>
                  </VBox>
                  

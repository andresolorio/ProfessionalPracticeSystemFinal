                        <Label style="-fx-font-weight: bold;" text="Menú Coordinador" textFill="#0c4c84">
                           <font>
                              <Font name="System Bold" size="28.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  
                  <VBox alignment="TOP_RIGHT" prefWidth="340.0" spacing="2.0">
                     <children>
                        <Label fx:id="welcomeLabel" text="Bienvenido: Cargando..." textFill="#0c4c84">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="sessionDetailsLabel" text="Ingreso al sistema: --/--/---- --:--" textFill="#666666">
                           <font>
                              <Font size="11.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
               <VBox.margin>
                  <Insets left="15.0" right="15.0" top="5.0" />
               </VBox.margin>
            </HBox>
            
            <Separator prefWidth="200.0" style="-fx-opacity: 0.6;">
               <VBox.margin>
                  <Insets bottom="10.0" left="15.0" right="15.0" />
               </VBox.margin>
            </Separator>
            
            <GridPane hgap="25.0" vgap="20.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="210.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="210.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  
                  <VBox spacing="10.0" style="-fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-color: #fafafa; -fx-background-radius: 8; -fx-padding: 15;">
